import csv
import glob
import os
import re


def resolve_project_root():
    candidate_roots = [
        os.environ.get("APABENCHMARK_FINAL_ROOT"),
        os.environ.get("APABENCHMARK_ROOT"),
        os.getcwd(),
        os.path.abspath(os.path.join(os.getcwd(), "..", "..")),
    ]
    for root in candidate_roots:
        if not root:
            continue
        data_dir = os.path.join(root, "data")
        sim_gt_dir = os.path.join(data_dir, "sim_data", "bam")
        sim_result_dir = os.path.join(data_dir, "result", "benchmark", "sim_bam")
        if os.path.isdir(sim_gt_dir) and os.path.isdir(sim_result_dir):
            return root
    raise FileNotFoundError(
        "Cannot resolve benchmark project root. Set APABENCHMARK_FINAL_ROOT to a directory containing data/sim_data/bam and data/result/benchmark/sim_bam."
    )


def resolve_workflow_dir():
    env_dir = os.environ.get("APABENCHMARK_BENCHMARK5_DIR")
    if env_dir:
        return env_dir
    if "workflow" in globals() and getattr(workflow, "basedir", None):
        return workflow.basedir
    return os.getcwd()


def resolve_gene_tag(sim_ground_truth_dir):
    env_tag = os.environ.get("APABENCHMARK_GENE_TAG")
    if env_tag:
        return env_tag

    tag_counts = {}
    for path in glob.glob(os.path.join(sim_ground_truth_dir, "*.bam.expr.tsv")):
        match = re.search(r"(gn\d+)", os.path.basename(path))
        if not match:
            continue
        tag = match.group(1)
        tag_counts[tag] = tag_counts.get(tag, 0) + 1

    if tag_counts:
        return sorted(tag_counts.items(), key=lambda item: (-item[1], item[0]))[0][0]

    return "gn2000"


def resolve_dapars_exclude_file(data_dir):
    env_file = os.environ.get("APABENCHMARK_DAPARS2_EXCLUDE_FILE")
    candidates = [
        env_file,
        os.path.join(data_dir, "dapars2_single_group_exclude.txt"),
        os.path.join(data_dir, "result", "dapars2_single_group_exclude.txt"),
    ]
    for candidate in candidates:
        if candidate and os.path.exists(candidate):
            return candidate
    return candidates[1]


def load_dapars_source_exclude_set(exclude_file):
    if not os.path.exists(exclude_file):
        return set()

    excluded = set()
    with open(exclude_file, "r", encoding="utf-8") as fh:
        for raw_line in fh:
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            sample_key = line.split("\t")[0]
            if "/" not in sample_key:
                sample_key = f"dapars2/{sample_key}"
            excluded.add(sample_key)
    return excluded


def has_required_dapars_groups(result_file, group1, group2):
    required = {
        f"{group1}_long_exp",
        f"{group1}_short_exp",
        f"{group2}_long_exp",
        f"{group2}_short_exp",
    }
    try:
        with open(result_file, "r", encoding="utf-8", errors="ignore") as fh:
            header = fh.readline().strip()
    except OSError:
        return False

    if not header:
        return False
    columns = set(header.split("\t"))
    return required.issubset(columns)


def parse_positive_int(value, label):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        raise ValueError(f"{label} must be an integer >= 1, got: {value}")
    if parsed < 1:
        raise ValueError(f"{label} must be >= 1, got: {parsed}")
    return parsed


def resolve_positive_int(env_key, config_key, default_value):
    env_value = os.environ.get(env_key)
    if env_value is not None and str(env_value).strip() != "":
        return parse_positive_int(env_value, env_key)

    cfg_value = config.get(config_key)
    if cfg_value is not None and str(cfg_value).strip() != "":
        return parse_positive_int(cfg_value, f"config.{config_key}")

    return default_value


def resolve_pipeline_mode():
    allowed = {"sim", "raw", "both", "raw_parallel"}
    env_value = os.environ.get("APABENCHMARK_PIPELINE_MODE")
    cfg_value = config.get("pipeline_mode")
    raw_value = env_value if env_value is not None and str(env_value).strip() != "" else cfg_value
    if raw_value is None:
        return "sim"

    mode = str(raw_value).strip().lower()
    if mode not in allowed:
        raise ValueError(
            f"pipeline_mode must be one of {sorted(allowed)}, got: {raw_value}"
        )
    return mode


def resolve_raw_output_base(data_dir):
    env_value = os.environ.get("APABENCHMARK_RAW_OUTPUT_BASE")
    cfg_value = config.get("raw_output_base")
    raw_value = env_value if env_value is not None and str(env_value).strip() != "" else cfg_value
    if raw_value is None:
        return os.path.join(data_dir, "result", "raw")
    return os.path.abspath(str(raw_value))


def resolve_raw_run_id(default_value):
    env_value = os.environ.get("APABENCHMARK_RAW_RUN_ID")
    cfg_value = config.get("raw_run_id")
    raw_value = env_value if env_value is not None and str(env_value).strip() != "" else cfg_value
    run_id = str(raw_value if raw_value is not None else default_value).strip()
    run_id = re.sub(r"[^A-Za-z0-9_.-]+", "_", run_id).strip("._")
    if not run_id:
        raise ValueError("raw_run_id resolved to empty value; set APABENCHMARK_RAW_RUN_ID or config.raw_run_id")
    return run_id


def resolve_dexseq_split_num(default_value):
    return resolve_positive_int("APABENCHMARK_DEXSEQ_SPLIT_NUM", "dexseq_split_num", default_value)


def infer_raw_manifest_defaults(raw_manifest_dir):
    top3_path = os.path.join(raw_manifest_dir, "sample_top3_celltypes.tsv")
    pair_path = os.path.join(raw_manifest_dir, "sample_pair_manifest.tsv")

    sample_count = 5
    pair_rank_max = 1

    if os.path.exists(top3_path):
        sample_set = set()
        with open(top3_path, "r", encoding="utf-8", newline="") as fh:
            reader = csv.DictReader(fh, delimiter="\t")
            for row in reader:
                sample = (row.get("sample") or "").strip()
                if sample:
                    sample_set.add(sample)
        if sample_set:
            sample_count = len(sample_set)

    if os.path.exists(pair_path):
        max_rank = None
        with open(pair_path, "r", encoding="utf-8", newline="") as fh:
            reader = csv.DictReader(fh, delimiter="\t")
            for row in reader:
                rank_text = (row.get("pair_rank") or "").strip()
                if not rank_text:
                    continue
                rank = parse_positive_int(rank_text, "raw_pair_manifest.pair_rank")
                if max_rank is None or rank > max_rank:
                    max_rank = rank
        if max_rank is not None:
            pair_rank_max = max_rank

    return sample_count, pair_rank_max


