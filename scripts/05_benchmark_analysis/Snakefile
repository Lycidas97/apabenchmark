def get_tool(wildcards):
    return wildcards.sample.split("/")[0]


def get_gt_bed(wildcards):
    sample_name = get_sample_id(wildcards)
    sample_parts = sample_name.split("_")
    genome = extract_genome_from_sample_name(sample_name)
    gene_number = sample_parts[-2]
    pas_rep = sample_parts[-3].replace("pas", "")
    return os.path.join(SIM_PAS_DIR, f"{genome}_sim_pas_{gene_number}_rep{pas_rep}.bed")


def get_gt_mtx(wildcards):
    bam = wildcards.sample.split("/")[-1]
    return os.path.join(SIM_GROUND_TRUTH_DIR, f"{bam}.bam.expr.tsv")


def get_pd_pas(wildcards):
    sample_dir = os.path.join(SIM_RESULT_DIR, wildcards.sample)
    preferred_path = os.path.join(sample_dir, "pas_fix.bed")
    fallback_path = os.path.join(sample_dir, "pas.bed")
    if os.path.exists(preferred_path):
        return preferred_path
    if os.path.exists(fallback_path):
        return fallback_path
    raise FileNotFoundError(
        f"No PAS BED file found for {wildcards.sample}. Expected pas_fix.bed or pas.bed in {sample_dir}."
    )


def get_sample_id(wildcards):
    return wildcards.sample.split("/")[-1]


def get_gt_apa_for_dapars_source(wildcards):
    sample_id = get_sample_id(wildcards)
    return os.path.join(
        DIFFERENTIAL_APA_GROUND_TRUTH_DIR,
        sample_id,
        f"{SCMAPA_GROUP1}_vs_{SCMAPA_GROUP2}",
        "APA_results.txt",
    )


def get_gt_mtx_for_ground_truth(wildcards):
    return os.path.join(SIM_GROUND_TRUTH_DIR, f"{wildcards.sample}.bam.expr.tsv")


def extract_genome_from_sample_name(sample_name):
    sample_parts = sample_name.split("_")
    if len(sample_parts) < 4:
        raise ValueError(f"Cannot parse genome token from sample name: {sample_name}")
    genome_token = sample_parts[-4]
    if genome_token not in {"hg38", "mm10"}:
        raise ValueError(
            f"Unsupported genome token '{genome_token}' in sample name {sample_name}. Expected one of: hg38, mm10."
        )
    return genome_token


def get_genome_size(wildcards):
    sample_name = get_sample_id(wildcards)
    genome_name = extract_genome_from_sample_name(sample_name)
    return os.path.join(TOOL_REFERENCE_DIR, f"{genome_name}.chrom.sizes")

def get_species_from_sample(sample_name):
    """Extract species from sample name based on genome annotation"""
    if "hg38" in sample_name or "human" in sample_name.lower():
        return "human"
    elif "mm10" in sample_name or "mouse" in sample_name.lower():
        return "mouse"
    else:
        # Default to mouse for mm10 in this dataset
        return "mouse"

def get_species_wildcards(wildcards):
    """Get species from wildcards for both sample_dirs and ground_truth_samples"""
    return get_species_from_sample(wildcards.sample)


