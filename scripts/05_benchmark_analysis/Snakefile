            --pair-label "{wildcards.pair_label}" \
            --tool "{wildcards.tool}" \
            --state-file "{output.state}" \
            --failure-file "{output.failure}"
        """


def get_raw_parallel_tool_ready_input(wildcards):
    if wildcards.tool in RAW_DAPARS_TOOLS:
        return os.path.join(
            RAW_RUN_ROOT,
            "raw_dapars2_parallel",
            "state",
            "prepare_dapars",
            wildcards.tool,
            wildcards.sample,
            f"{wildcards.pair_label}.done",
        )
    return os.path.join(
        RAW_RUN_ROOT,
        "raw_dapars2_parallel",
        "state",
        "prepare_nondapars",
        wildcards.tool,
        wildcards.sample,
        f"{wildcards.pair_label}.done",
    )


rule run_raw_dapars2_parallel_eval_pair_tool:
    wildcard_constraints:
        sample=".+",
        pair_label=".+",
        tool=".+",
    input:
        gt_done=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "state", "prepare_gt", "{sample}", "{pair_label}.done"),
        tool_done=get_raw_parallel_tool_ready_input,
    params:
        run_root=RAW_RUN_ROOT,
        script_root=WORKFLOW_DIR,
        conda_exe=CONDA_EXE,
        dexseq_env=DEXSEQ_ENV_NAME,
        scmapa_env=SCMAPA_ENV_NAME,
        script=os.path.join(SCRIPTS_DIR, "raw_parallel_eval_one.py"),
    output:
        perf=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "performance", "{tool}", "{sample}", "{pair_label}", "dapars2_performance.tsv"),
        failure=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "failures", "eval", "{tool}", "{sample}", "{pair_label}", "failure.tsv"),
        state=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "state", "eval", "{tool}", "{sample}", "{pair_label}.done"),
    shell:
        """
        python3 "{params.script}" \
            --run-root "{params.run_root}" \
            --script-root "{params.script_root}" \
            --conda-exe "{params.conda_exe}" \
            --dexseq-env "{params.dexseq_env}" \
            --scmapa-env "{params.scmapa_env}" \
            --sample "{wildcards.sample}" \
            --pair-label "{wildcards.pair_label}" \
            --tool "{wildcards.tool}" \
            --perf-out "{output.perf}" \
            --failure-file "{output.failure}" \
            --state-file "{output.state}"
        """


rule run_raw_dapars2_parallel_aggregate:
    input:
        eval_done=expand_raw_pair_tools(
            os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "state", "eval", "{tool}", "{sample}", "{pair_label}.done"),
            RAW_PARALLEL_TOOLS,
        ),
    params:
        run_root=RAW_RUN_ROOT,
        script=os.path.join(SCRIPTS_DIR, "raw_parallel_aggregate.py"),
    output:
        metrics=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_metrics.tsv"),
        missing_failed=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_missing_failed.tsv"),
        gt_failures=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_gt_failures.tsv"),
        nondapars_failures=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_nondapars_failures.tsv"),
        dapars_failures=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_dapars_failures.tsv"),
        done=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "state", "eval.done"),
    shell:
        """
        python3 "{params.script}" \
            --run-root "{params.run_root}" \
            --done-file "{output.done}"
        """


rule run_raw_dapars2_summary_alias:
    input:
        metrics=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_metrics.tsv"),
        missing=os.path.join(RAW_RUN_ROOT, "raw_dapars2_parallel", "summary", "raw_dapars2_parallel_missing_failed.tsv"),
    output:
        metrics=os.path.join(RAW_RUN_ROOT, "raw_dapars2_format", "summary", "raw_dapars2_metrics.tsv"),
        missing=os.path.join(RAW_RUN_ROOT, "raw_dapars2_format", "summary", "raw_dapars2_missing_failed.tsv"),
    shell:
        """
        mkdir -p "$(dirname "{output.metrics}")"
        cp "{input.metrics}" "{output.metrics}"
        cp "{input.missing}" "{output.missing}"
        """
