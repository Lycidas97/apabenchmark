rule run_raw_dapars2_parallel_prepare_inputs:
    input:
        sample_top3=os.path.join(RAW_MANIFEST_DIR, "sample_top3_celltypes.tsv"),
        pair_manifest=os.path.join(RAW_MANIFEST_DIR, "sample_pair_manifest.tsv"),
        benchmark_script=RAW_BENCHMARK_SCRIPT,
    params:
        project_root=APABENCHMARK_PROJECT_ROOT,
        top_n=RAW_TOP_N,
        split_num=RAW_SPLIT_NUM,
        pair_rank_max=RAW_PAIR_RANK_MAX,
        conda_exe=CONDA_EXE,
        dexseq_env=DEXSEQ_ENV_NAME,
        scmapa_env=SCMAPA_ENV_NAME,
        dapars_script_root=WORKFLOW_DIR,
        output_root=RAW_RUN_ROOT,
    output:
        prep_done=RAW_DAPARS2_PARALLEL_PREP_DONE,
        sample_top3=os.path.join(RAW_RUN_ROOT, "raw_pair_manifest", "sample_top3_celltypes.tsv"),
        pair_manifest=os.path.join(RAW_RUN_ROOT, "raw_pair_manifest", "sample_pair_manifest.tsv"),
        prep_meta=os.path.join(RAW_RUN_ROOT, "raw_pair_manifest", "prepare_metadata.tsv"),
        qc=os.path.join(RAW_RUN_ROOT, "raw_qc", "pas_filter_overview.tsv"),
    shell:
        """
        mkdir -p "{params.output_root}"
        python3 "{input.benchmark_script}" \
            --project-root "{params.project_root}" \
            --top-n {params.top_n} \
            --split-num {params.split_num} \
            --pair-rank-max {params.pair_rank_max} \
            --conda-exe "{params.conda_exe}" \
            --dexseq-env "{params.dexseq_env}" \
            --scmapa-env "{params.scmapa_env}" \
            --dapars-script-root "{params.dapars_script_root}" \
            --output-root "{params.output_root}" \
            --prepare-only
        echo ok > "{output.prep_done}"
        """


def _raw_parallel_upstream_inputs(wildcards):
    return [RAW_DAPARS2_PARALLEL_PREP_DONE]


rule run_raw_performance_pair:
    wildcard_constraints:
        sample=".+",
        pair_label=".+",
        tool=".+",
    input:
        prep_done=RAW_DAPARS2_PARALLEL_PREP_DONE,
    params:
        run_root=RAW_RUN_ROOT,
        script_root=WORKFLOW_DIR,
        conda_exe=CONDA_EXE,
        dexseq_env=DEXSEQ_ENV_NAME,
        split_num=RAW_SPLIT_NUM,
        script=os.path.join(SCRIPTS_DIR, "raw_performance_eval_one.py"),
    output:
        match=os.path.join(RAW_RUN_ROOT, "raw_performance", "by_sample_pair_tool", "{tool}", "{sample}__{pair_label}_match_performance.tsv"),
        quantify=os.path.join(RAW_RUN_ROOT, "raw_performance", "by_sample_pair_tool", "{tool}", "{sample}__{pair_label}_pas_quantify_performance.tsv"),
        deapa=os.path.join(RAW_RUN_ROOT, "raw_performance", "by_sample_pair_tool", "{tool}", "{sample}__{pair_label}_de_apa_performance.tsv"),
        state=os.path.join(RAW_RUN_ROOT, "raw_performance", "state", "eval", "{tool}", "{sample}", "{pair_label}.done"),
        failure=os.path.join(RAW_RUN_ROOT, "raw_performance", "failures", "eval", "{tool}", "{sample}", "{pair_label}", "failure.tsv"),
    shell:
        """
        python3 "{params.script}" \
            --run-root "{params.run_root}" \
            --script-root "{params.script_root}" \
            --conda-exe "{params.conda_exe}" \
            --dexseq-env "{params.dexseq_env}" \
            --split-num {params.split_num} \
            --sample "{wildcards.sample}" \
            --pair-label "{wildcards.pair_label}" \
            --tool "{wildcards.tool}" \
            --state-file "{output.state}" \
            --failure-file "{output.failure}"
        """


rule run_raw_performance_aggregate:
    input:
        pair_done=expand_raw_pair_tools(
            os.path.join(RAW_RUN_ROOT, "raw_performance", "state", "eval", "{tool}", "{sample}", "{pair_label}.done"),
            RAW_STANDARD_TOOLS,
        ),
    params:
        run_root=RAW_RUN_ROOT,
        script=os.path.join(SCRIPTS_DIR, "raw_performance_aggregate.py"),
    output:
        match=os.path.join(RAW_RUN_ROOT, "raw_performance", "summary", "raw_performance_match_metrics.tsv"),
        quantify=os.path.join(RAW_RUN_ROOT, "raw_performance", "summary", "raw_performance_pas_quantify_metrics.tsv"),
        deapa=os.path.join(RAW_RUN_ROOT, "raw_performance", "summary", "raw_performance_de_apa_metrics.tsv"),
        missing_failed=os.path.join(RAW_RUN_ROOT, "raw_performance", "summary", "raw_performance_missing_failed.tsv"),
        done=os.path.join(RAW_RUN_ROOT, "raw_performance", "state", "summary.done"),
    shell:
        """
        python3 "{params.script}" \
            --run-root "{params.run_root}" \
            --done-file "{output.done}"
        """


