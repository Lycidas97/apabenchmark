def _read_tsv(path):
    with open(path, "r", encoding="utf-8", newline="") as fh:
        return list(csv.DictReader(fh, delimiter="\t"))


def resolve_raw_selected_pairs(raw_manifest_dir, top_n, pair_rank_max):
    top3_rows = _read_tsv(os.path.join(raw_manifest_dir, "sample_top3_celltypes.tsv"))
    pair_rows = _read_tsv(os.path.join(raw_manifest_dir, "sample_pair_manifest.tsv"))
    totals = {}
    for row in top3_rows:
        sample = row["sample"]
        totals[sample] = totals.get(sample, 0) + int(row["cell_count"])

    ranked = sorted(totals.items(), key=lambda x: (-x[1], x[0]))
    selected_samples = {s for s, _ in ranked[:top_n]}
    selected_pairs = [
        row
        for row in pair_rows
        if row["sample"] in selected_samples and int(row["pair_rank"]) <= pair_rank_max
    ]
    selected_pairs.sort(key=lambda r: (r["sample"], int(r["pair_rank"])))
    return selected_pairs


RAW_SELECTED_PAIR_ROWS = resolve_raw_selected_pairs(RAW_MANIFEST_DIR, RAW_TOP_N, RAW_PAIR_RANK_MAX)
RAW_PAIR_SAMPLES = [row["sample"] for row in RAW_SELECTED_PAIR_ROWS]
RAW_PAIR_LABELS = [row["pair_label"] for row in RAW_SELECTED_PAIR_ROWS]


def expand_raw_pairs(pattern):
    return expand(pattern, zip, sample=RAW_PAIR_SAMPLES, pair_label=RAW_PAIR_LABELS)


def expand_raw_pair_tools(pattern, tools):
    samples = []
    pair_labels = []
    tool_vals = []
    for row in RAW_SELECTED_PAIR_ROWS:
        for tool in tools:
            samples.append(row["sample"])
            pair_labels.append(row["pair_label"])
            tool_vals.append(tool)
    return expand(pattern, zip, sample=samples, pair_label=pair_labels, tool=tool_vals)

