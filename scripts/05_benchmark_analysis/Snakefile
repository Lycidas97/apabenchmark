rule all:
    input:
        ALL_TARGETS

rule calculate_performance:
    wildcard_constraints:
        sample="(?!dapars2/|scmapa/).+"
    input:
        pd_pas=get_pd_pas,
        pd_mtx=os.path.join(SIM_RESULT_DIR, "{sample}", "pas_counts.tsv"),
        gt_pas=get_gt_bed,
        gt_mtx=get_gt_mtx,
    params:
        tool=get_tool,
        output_dir=PERFORMANCE_DIR,
        sample_id=get_sample_id,
        dexseq_split_num=DEXSEQ_SPLIT_NUM,
        conda_exe=CONDA_EXE,
        conda_env=DEXSEQ_ENV_NAME,
        calculate_performance_script=os.path.join(SCRIPTS_DIR, "calculate_benchmark_performance.R"),
    output:        
        os.path.join(PERFORMANCE_DIR, "{sample}_match_performance.tsv"),
        os.path.join(PERFORMANCE_DIR, "{sample}_pas_quantify_performance.tsv"),
        os.path.join(PERFORMANCE_DIR, "{sample}_de_apa_performance.tsv"),
        os.path.join(PERFORMANCE_DIR, "{sample}_quality_report.tsv"),
        # os.path.join(DATA_DIR, "performance", "{sample}_match_pas.csv"),
        # os.path.join(DATA_DIR, "performance", "{sample}_match_te.csv"),
    shell:
        """
        "{params.conda_exe}" run -n "{params.conda_env}" \
          Rscript "{params.calculate_performance_script}" \
            --pd_pas {input.pd_pas} \
            --pd_mtx {input.pd_mtx} \
            --gt_pas {input.gt_pas} \
            --gt_mtx {input.gt_mtx} \
            --tool {params.tool} \
            --sample {params.sample_id} \
            --output_dir {params.output_dir} \
            --dexseq_split_num {params.dexseq_split_num} \
        """

rule calculate_te_gap:
    input:
        pd_pas=get_pd_pas,
        gt_pas=get_gt_bed,
        gt_mtx=get_gt_mtx,
        genome_size=get_genome_size,
    params:
        tool=get_tool,
        output_dir=PERFORMANCE_DIR,
        sample_id=get_sample_id,
        calculate_te_gap_script=os.path.join(SCRIPTS_DIR, "calculate_te_gap.py"),
    output:
        os.path.join(PERFORMANCE_DIR, "{sample}_te_gap.tsv"),
    shell:
        """
        python "{params.calculate_te_gap_script}" \
            --pd_pas {input.pd_pas} \
            --gt_pas {input.gt_pas} \
            --gt_mtx {input.gt_mtx} \
            --tool {params.tool} \
            --sample {params.sample_id} \
            --output_dir {params.output_dir} \
            --genome_size {input.genome_size}
        """


rule calculate_dapars2_de_apa_performance:
    wildcard_constraints:
        sample="(dapars2|scmapa)/.+"
    input:
        pd_apa=os.path.join(
            DIFFERENTIAL_APA_DIR,
            "{sample}",
            f"{SCMAPA_DAPARS_GROUP1}_vs_{SCMAPA_DAPARS_GROUP2}",
            "APA_results.txt",
        ),
        gt_apa=get_gt_apa_for_dapars_source,
    params:
        tool=get_tool,
        sample_id=get_sample_id,
        conda_exe=CONDA_EXE,
        conda_env=DEXSEQ_ENV_NAME,
        match_type=f"{SCMAPA_DAPARS_GROUP1}_vs_{SCMAPA_DAPARS_GROUP2}",
        filter_type_1=f"scmapa_adPval_{SCMAPA_AD_PVAL}",
        filter_type_2=f"scmapa_or_{SCMAPA_OR_CUTOFF}",
        script=os.path.join(SCRIPTS_DIR, "calculate_dapars2_de_apa_performance.R"),
    output:
        os.path.join(PERFORMANCE_DIR, "{sample}_de_apa_performance.tsv"),
    shell:
        """
        "{params.conda_exe}" run -n "{params.conda_env}" \
          Rscript "{params.script}" \
            --pd_apa {input.pd_apa} \
            --gt_apa {input.gt_apa} \
            --tool {params.tool} \
            --sample {params.sample_id} \
            --match_type {params.match_type} \
            --filter_type_1 {params.filter_type_1} \
            --filter_type_2 {params.filter_type_2} \
            --output {output}
        """


ruleorder: calculate_dapars2_de_apa_performance > calculate_performance

rule convert_to_dapars2_format:
    input:
        pd_pas=get_pd_pas,
        pd_mtx=os.path.join(SIM_RESULT_DIR, "{sample}", "pas_counts.tsv"),
        gt_pas=get_gt_bed,
        gt_mtx=get_gt_mtx,
    params:
        output_dir=DAPARS2_FORMAT_DIR,
        sample_id=get_sample_id,
        conda_exe=CONDA_EXE,
        conda_env=SCMAPA_ENV_NAME,
        integrated_converter_script=os.path.join(SCMAPA_DIR, "integrated_pas_to_dapars2_converter.R"),
    output:
        os.path.join(DAPARS2_FORMAT_DIR, "{sample}_dapars2_format.txt"),
    shell:
        """
        # Create output directory if it doesn't exist
        mkdir -p {params.output_dir}
        mkdir -p "$(dirname {output})"

        # Use the integrated converter script to convert to DaPars2 format
        "{params.conda_exe}" run -n "{params.conda_env}" \
          Rscript "{params.integrated_converter_script}" \
            --pas_counts {input.pd_mtx} \
            --pas_coords {input.pd_pas} \
            --pas_annotation {input.gt_pas} \
            --celltype_info {input.gt_mtx} \
            -o {output} \
            --min_exp 0 \
            --min_cells 0
        """

rule convert_ground_truth_to_dapars2_format:
    input:
        gt_mtx=get_gt_mtx_for_ground_truth,
    params:
        output_dir=DAPARS2_FORMAT_GROUND_TRUTH_DIR,
        sample_id=get_sample_id,
        conda_exe=CONDA_EXE,
        conda_env=SCMAPA_ENV_NAME,
        multi_group_converter_script=os.path.join(SCMAPA_DIR, "multi_group_PAS_to_DaPars2_converter.R"),
    output:
        os.path.join(DAPARS2_FORMAT_GROUND_TRUTH_DIR, "{sample}_dapars2_format.txt"),
    shell:
        """
        # Create output directory if it doesn't exist
        mkdir -p {params.output_dir}

        # Use the multi_group converter script for ground truth
        "{params.conda_exe}" run -n "{params.conda_env}" \
          Rscript "{params.multi_group_converter_script}" \
            -i {input.gt_mtx} \
            -o {output} \
            --min_exp 0 \
            --min_cells 0
        """

rule run_differential_apa_analysis:
    input:
        dapars2_file=os.path.join(DAPARS2_FORMAT_DIR, "{sample}_dapars2_format.txt"),
    params:
        output_dir=os.path.join(DIFFERENTIAL_APA_DIR, "{sample}"),
        conda_exe=CONDA_EXE,
        conda_env=SCMAPA_ENV_NAME,
        comparison_mode=SCMAPA_COMPARISON_MODE,
        group1=SCMAPA_GROUP1,
        group2=SCMAPA_GROUP2,
        na_cutoff=SCMAPA_NA_CUTOFF,
        cpm_cutoff_long=SCMAPA_CPM_CUTOFF_LONG,
        cpm_cutoff_short=SCMAPA_CPM_CUTOFF_SHORT,
        coverage_cutoff=SCMAPA_COVERAGE_CUTOFF,
        or_cutoff=SCMAPA_OR_CUTOFF,
        adPval=SCMAPA_AD_PVAL,
        differential_apa_script=os.path.join(SCMAPA_DIR, "parameterized_scmapa_analysis.R"),
    output:
        os.path.join(DIFFERENTIAL_APA_DIR, "{sample}", f"{SCMAPA_GROUP1}_vs_{SCMAPA_GROUP2}", "APA_results.txt"),
    shell:
        """
        # Create output directory if it doesn't exist
        mkdir -p {params.output_dir}

        # Run differential APA analysis using scMAPA
        "{params.conda_exe}" run -n "{params.conda_env}" \
          Rscript "{params.differential_apa_script}" \
            -i {input.dapars2_file} \
            -o {params.output_dir} \
            --comparison_mode {params.comparison_mode} \
            --group1 {params.group1} \
            --group2 {params.group2} \
            --NAcutoff {params.na_cutoff} \
            --CPMcutoff_L {params.cpm_cutoff_long} \
            --CPMcutoff_S {params.cpm_cutoff_short} \
            --coverageCutoff {params.coverage_cutoff} \
            --ORcutoff {params.or_cutoff} \
            --adPval {params.adPval} \
        """

rule run_differential_apa_analysis_dapars_sources:
