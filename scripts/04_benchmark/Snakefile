configfile: "snakemake_profile/sample.yaml"
# import glob
import os 
from collections.abc import Mapping

CURRENT_PATH = os.path.join(os.path.abspath(os.getcwd()), "")


def get_sample_section(section_name):
    section = config.get(section_name) or {}
    if not isinstance(section, Mapping):
        raise ValueError(f"{section_name} must be a mapping in sample config, got: {type(section).__name__}")
    return section


sim_sample_cfg = get_sample_section("sim_sample")
raw_sample_cfg = get_sample_section("raw_sample")
pf_sample_cfg = get_sample_section("pf_sample")

def infer_sample_genome(sample):
    parts = sample.split("_")
    return next((g for g in ("mm10", "hg38") if g in parts), None)


def require_sample_genome(sample):
    genome = infer_sample_genome(sample)
    if genome is None:
        raise ValueError(
            f"Sim sample name must include genome token mm10/hg38, got: {sample}. "
            "Expected pattern like '*_mm10_pas1_gn5000_rep1'."
        )
    return genome

supported_sim_genomes_cfg = config.get("supported_sim_genomes", ["mm10", "hg38"])
if isinstance(supported_sim_genomes_cfg, str):
    supported_sim_genomes = {x.strip() for x in supported_sim_genomes_cfg.split(",") if x.strip()}
else:
    supported_sim_genomes = set(supported_sim_genomes_cfg)
if not supported_sim_genomes:
    raise ValueError("supported_sim_genomes is empty. Please set at least one genome, e.g. ['mm10'].")
all_sim_bam_list = sim_sample_cfg.keys()
all_sim_bam_list = [x.split("/")[-1].replace(".bai", "") for x in all_sim_bam_list]
all_sim_sample_list = [x.replace(".bam", "") for x in all_sim_bam_list]
invalid_sim_samples = [x for x in all_sim_sample_list if infer_sample_genome(x) is None]
if invalid_sim_samples:
    preview_count = 10
    sample_preview = ", ".join(invalid_sim_samples[:preview_count])
    remaining = len(invalid_sim_samples) - preview_count
    remaining_msg = f" (+{remaining} more)" if remaining > 0 else ""
    raise ValueError(
        "Found sim sample names without genome token mm10/hg38. "
        "Rename/re-generate them to include token, e.g. '*_mm10_pas1_gn5000_rep1'. "
        f"Invalid samples ({len(invalid_sim_samples)}): {sample_preview}{remaining_msg}"
    )

sim_sample_genome = {x: require_sample_genome(x) for x in all_sim_sample_list}
sim_sample_list = [x for x in all_sim_sample_list if sim_sample_genome[x] in supported_sim_genomes]
sim_bam_list = [f"{x}.bam" for x in sim_sample_list]
excluded_sim_samples = [x for x in all_sim_sample_list if x not in sim_sample_list]
if excluded_sim_samples:
    print(
        f"[04_benchmark] Excluding {len(excluded_sim_samples)} sim samples with unsupported genomes; "
        f"supported_sim_genomes={sorted(supported_sim_genomes)}"
    )
if not sim_sample_list:
    raise ValueError("No sim samples left after genome filtering. Check supported_sim_genomes in config.")

raw_bam_list = raw_sample_cfg.keys()
raw_bam_list = [x.split("/")[-1].replace(".bai", "") for x in raw_bam_list]
raw_sample_list = [x.replace(".bam", "") for x in raw_bam_list]

pf_bam_list = pf_sample_cfg.keys()
pf_bam_list = [x.split("/")[-1].replace(".bai", "") for x in pf_bam_list]
pf_sample_list = [x.replace(".bam", "") for x in pf_bam_list]

tool_list = ["sierra", "scapatrap", "scape", "scapa", "infernape", "scapture"]

def get_pf_read_length(wildcards):
    return pf_sample_cfg[wildcards.pf_sample]["read_length"]

def get_sim_read_length(wildcards):
    return sim_sample_cfg[wildcards.sim_sample]["read_length"]

def get_raw_read_length(wildcards):
    return raw_sample_cfg[wildcards.raw_sample]["read_length"]

def resolve_sample_name(wildcards):
    if hasattr(wildcards, "sample"):
        return wildcards.sample
    if hasattr(wildcards, "sim_sample"):
        return wildcards.sim_sample
    raise ValueError("Cannot resolve sample name from wildcards")

def parse_sim_sample_tokens(sample):
    parts = sample.split("_")
    genome = require_sample_genome(sample)

    pas_token = next((p for p in parts if p.startswith("pas") and p[3:].isdigit()), None)
    gene_token = next((g for g in parts if g.startswith("gn") and g[2:].isdigit()), None)
    if pas_token is None or gene_token is None:
        raise ValueError(f"Cannot infer pas/gene tokens from sample name: {sample}")

    pas_rep = pas_token.replace("pas", "")
    return genome, gene_token, pas_rep

def get_gt_bed(wildcards):
    sample = resolve_sample_name(wildcards)
    genome, gene_number, pas_rep = parse_sim_sample_tokens(sample)
    return f"../../data/sim_data/sim_pas/{genome}_sim_pas_{gene_number}_rep{pas_rep}.bed"

def get_gt_mtx(wildcards):
    bam = resolve_sample_name(wildcards).split("/")[-1]
    return f"../../data/sim_data/bam/{bam}.bam.expr.tsv"

def get_sim_genome(wildcards):
    return require_sample_genome(wildcards.sim_sample)

def get_sim_sierra_reference(wildcards):
    genome = get_sim_genome(wildcards)
    if genome == "mm10":
        return "../../data/raw_data/tool_reference/gencode.vM25.annotation.gtf"
    if genome == "hg38":
        return "../../data/raw_data/tool_reference/gencode.v40.annotation.gtf"
    raise ValueError(f"Unsupported sim genome for Sierra: {genome}")

def get_sim_scape_reference(wildcards):
    genome = get_sim_genome(wildcards)
    if genome == "mm10":
        return "../../data/raw_data/tool_reference/gencode.vM25.scape_utr.bed"
    if genome == "hg38":
        return "../../data/raw_data/tool_reference/gencode.v40.scape_utr.bed"
    raise ValueError(f"Unsupported sim genome for SCAPE: {genome}")

def get_pf_sierra_reference(_wildcards):
    return "../../data/raw_data/tool_reference/gencode.vM25.annotation.gtf"

def get_pf_scape_reference(_wildcards):
    return "../../data/raw_data/tool_reference/gencode.vM25.scape_utr.bed"


wildcard_constraints:
    sim_sample = "|".join(sim_sample_list),
    raw_sample = "|".join(raw_sample_list),
    pf_sample = "|".join(pf_sample_list)

