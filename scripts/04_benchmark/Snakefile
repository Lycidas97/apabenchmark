rule calculate_performance:
    input:
        pd_pas="../../data/result/benchmark/sim_bam/{tool}/{sample}/pas.bed",
        pd_mtx="../../data/result/benchmark/sim_bam/{tool}/{sample}/pas_counts.tsv",
        gt_pas=get_gt_bed,
        gt_mtx=get_gt_mtx,
    params:
        tool=lambda wildcards: wildcards.tool,
        output_dir="../../data/result/tool_performance",
        sample_id=lambda wildcards: wildcards.sample,
    output:        
        "../../data/result/tool_performance/{tool}/{sample}_match_performance.tsv",
        "../../data/result/tool_performance/{tool}/{sample}_pas_quantify_performance.tsv",
        "../../data/result/tool_performance/{tool}/{sample}_de_apa_performance.tsv",
    conda: "dexseq"
    shell:
        """
        Rscript calculate_benchmark_performance.R \
            --pd_pas {input.pd_pas} \
            --pd_mtx {input.pd_mtx} \
            --gt_pas {input.gt_pas} \
            --gt_mtx {input.gt_mtx} \
            --tool {params.tool} \
            --sample {params.sample_id} \
            --output_dir {params.output_dir} \
        """
